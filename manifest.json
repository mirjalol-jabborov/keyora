{
  "manifest_version": 3,
  "name": "Keyora",
  "version": "0.1.0",
  "description": "Create custom text snippets that expand with keyboard shortcuts",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],

  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Keyora"
  },
  "background": {
    "service_worker": "src/background/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "assets/icons/icon-16.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  }
}
